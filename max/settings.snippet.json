{
  "_comment": "MAX tier. Merge these keys into ~/.claude/settings.json (do not overwrite the whole file if you already have one). effortLevel never below high; Opus is used per-agent via each agent's `model:` field.",
  "effortLevel": "high",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(npm:*)", "Bash(npx:*)", "Bash(node:*)", "Bash(tsc:*)",
      "Bash(git add:*)", "Bash(git commit:*)", "Bash(git status:*)", "Bash(git diff:*)",
      "Bash(git log:*)", "Bash(git show:*)", "Bash(git branch:*)", "Bash(git checkout:*)",
      "Bash(git restore:*)", "Bash(git stash:*)", "Bash(git worktree:*)", "Bash(git rev-parse:*)",
      "Bash(mkdir:*)", "Bash(cp:*)", "Bash(mv:*)", "Bash(cat:*)", "Bash(ls:*)", "Bash(echo:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)", "Bash(sudo:*)", "Bash(curl:*)", "Bash(wget:*)", "Bash(npm publish:*)"
    ]
  }
}
